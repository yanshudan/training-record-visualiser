{
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/assets/*",
            "/*.{js,css,png,svg,ico,json,webmanifest,txt}"
        ]
    },
    "mimeTypes": {
        ".json": "application/json"
    },
    "responseOverrides": {
        "404": {
            "rewrite": "/index.html",
            "statusCode": 200
        }
    }
}