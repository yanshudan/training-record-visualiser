# ------------------------------------------------------------------
# Storage configuration. Copy to `.env.local` and fill in values.
# Account KEYS must never be placed here for the client build.
# ------------------------------------------------------------------

# Which storage provider the client uses: "sas" | "backend" | "local"
VITE_STORAGE_PROVIDER=local

# --- SAS mode (single personal user, no backend) ---
# A container-scoped SAS URL with read/write/list/create permissions.
# Example: https://<account>.blob.core.windows.net/<container>?sv=...&sig=...
VITE_BLOB_CONTAINER_SAS_URL=

# Fixed user id used in SAS mode (multi-user layout is still used on disk).
VITE_SAS_USER_ID=me

# --- Backend mode (true multi-user) ---
# Base URL of the backend that authenticates the user and issues per-user SAS.
VITE_BACKEND_BASE_URL=http://localhost:7071
